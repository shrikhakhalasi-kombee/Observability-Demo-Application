{
  "annotations": { "list": [] },
  "description": "Tempo trace explorer for the Laravel Observability Demo",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "traceDuration" }, "properties": [{ "id": "unit", "value": "ms" }, { "id": "displayName", "value": "Duration (ms)" }] },
          { "matcher": { "id": "byName", "options": "traceID" }, "properties": [{ "id": "displayName", "value": "Trace ID" }] },
          { "matcher": { "id": "byName", "options": "startTime" }, "properties": [{ "id": "displayName", "value": "Start Time" }] },
          { "matcher": { "id": "byName", "options": "traceService" }, "properties": [{ "id": "displayName", "value": "Service" }] },
          { "matcher": { "id": "byName", "options": "traceName" }, "properties": [{ "id": "displayName", "value": "Name" }] }
        ]
      },
      "options": { "footer": { "show": false }, "sortBy": [{ "desc": true, "displayName": "Start Time" }] },
      "targets": [{
        "datasource": { "type": "tempo", "uid": "tempo" },
        "queryType": "traceql",
        "refId": "A",
        "query": "{resource.service.name=\"laravel-observability-demo\"}",
        "tableType": "traces",
        "limit": 20
      }],
      "title": "Recent Traces",
      "type": "table"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 18 },
      "id": 2,
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 80, "lineWidth": 1 } },
        "overrides": []
      },
      "options": { "bucketSize": "auto", "fillOpacity": 80, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "targets": [{
        "datasource": { "type": "tempo", "uid": "tempo" },
        "queryType": "traceql",
        "refId": "A",
        "query": "{resource.service.name=\"laravel-observability-demo\"}",
        "tableType": "spans"
      }],
      "title": "Span Duration Distribution",
      "type": "histogram"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 18 },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "ns",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100000000 }, { "color": "red", "value": 500000000 }] },
          "custom": { "displayMode": "color-background" }
        },
        "overrides": []
      },
      "options": { "footer": { "show": false } },
      "targets": [{
        "datasource": { "type": "tempo", "uid": "tempo" },
        "queryType": "traceql",
        "refId": "A",
        "query": "{resource.service.name=\"laravel-observability-demo\"} | select(duration, name, resource.service.name)",
        "tableType": "spans",
        "limit": 20
      }],
      "title": "Slowest Spans (Top 20)",
      "type": "table"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["laravel", "observability", "traces"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Traces Explorer",
  "uid": "laravel-traces-explorer",
  "version": 3
}
