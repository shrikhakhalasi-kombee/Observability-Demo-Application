{
  "__inputs": [
    {
      "name": "DS_TEMPO",
      "label": "Tempo",
      "description": "",
      "type": "datasource",
      "pluginId": "tempo",
      "pluginName": "Tempo"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "tempo",
      "name": "Tempo",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "traces",
      "name": "Traces",
      "version": ""
    },
    {
      "type": "panel",
      "id": "histogram",
      "name": "Histogram",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Tempo-backed trace explorer with clickable trace IDs linked from Loki logs for the Laravel Observability Demo",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "tempo",
        "uid": "${DS_TEMPO}"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "filters": [
            {
              "id": "service-name",
              "operator": "=",
              "scope": "resource",
              "tag": "service.name",
              "value": ["laravel-observability-demo"],
              "valueType": "string"
            }
          ],
          "limit": 20,
          "queryType": "traceql",
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "title": "Trace Search",
      "type": "traces"
    },
    {
      "datasource": {
        "type": "tempo",
        "uid": "${DS_TEMPO}"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 16 },
      "id": 2,
      "options": {
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "queryType": "traceql",
          "refId": "A",
          "query": "{resource.service.name=\"laravel-observability-demo\"}",
          "tableType": "traces"
        }
      ],
      "title": "Request Waterfall — Trace Detail",
      "type": "traces"
    },
    {
      "datasource": {
        "type": "tempo",
        "uid": "${DS_TEMPO}"
      },
      "description": "Distribution of span durations across all spans for the Laravel service.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineWidth": 1
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 28 },
      "id": 3,
      "options": {
        "bucketSize": "auto",
        "combine": false,
        "fillOpacity": 80,
        "gradientMode": "none",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "queryType": "traceql",
          "refId": "A",
          "query": "{resource.service.name=\"laravel-observability-demo\"}",
          "tableType": "spans"
        }
      ],
      "title": "Span Duration Distribution",
      "type": "histogram"
    },
    {
      "datasource": {
        "type": "tempo",
        "uid": "${DS_TEMPO}"
      },
      "description": "Top 10 slowest spans by duration, grouped by service and span name.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "ms",
          "custom": { "displayMode": "color-background" }
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 28 },
      "id": 4,
      "options": {
        "sortBy": [{ "desc": true, "displayName": "Duration" }],
        "footer": { "show": false }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "queryType": "traceql",
          "refId": "A",
          "query": "{resource.service.name=\"laravel-observability-demo\"} | select(duration, name, resource.service.name) | sort(duration desc) | limit(10)",
          "tableType": "spans"
        }
      ],
      "title": "Slowest Service Spans (Top 10)",
      "type": "table"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["laravel", "observability", "traces"],
  "templating": {
    "list": []
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Traces Explorer",
  "uid": "laravel-traces-explorer",
  "version": 1,
  "weekStart": ""
}
